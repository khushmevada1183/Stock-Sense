{
  "name": "indian-stock-sense-frontend",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://khushmevada1183.github.io/Stock-Sense/",
  "scripts": {
    "dev": "start /b npm run api:dev && timeout /t 5 >nul && npm run frontend:dev",
    "dev:safe": "node scripts/start-dev.js",
    "dev:concurrent": "concurrently --kill-others --prefix-colors \"bgBlue.bold,bgGreen.bold\" --names \"API,FRONTEND\" \"npm run api:dev\" \"npm run frontend:dev\"",
    "frontend:dev": "npx next dev",
    "frontend:dev:wait": "node scripts/wait-and-start-frontend.js",
    "build": "node scripts/build-with-api.js",
    "build:simple": "node node_modules/next/dist/cli/next-build.js",
    "build:with-deps": "pnpm install --production=false && npm run build:simple",
    "start": "npx next start",
    "lint": "npx next lint",
    "clean": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules pnpm-lock.yaml && pnpm install",
    "export": "next export || echo 'Export included in build with Next.js 13+'",
    "build:static": "cross-env NODE_OPTIONS=--max_old_space_size=1024 npm run build && npx next export",
    "predeploy": "pnpm run build:static",
    "deploy": "gh-pages -d out",
    "api:dev": "node api/server.js",
    "api:start": "NODE_ENV=production node api/server.js",
    "dev:frontend": "npx next dev",
    "dev:backend": "node api/server.js",
    "dev:sequential": "npm run api:dev && npm run frontend:dev"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "axios": "^1.6.2",
    "bun": "^1.2.19",
    "chart.js": "^4.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "framer-motion": "^12.12.1",
    "gsap": "^3.12.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.292.0",
    "morgan": "^1.10.1",
    "next": "^15.4.5",
    "next-themes": "^0.2.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^4.12.0",
    "react-syntax-highlighter": "^15.6.1",
    "react-table": "^7.8.0",
    "recharts": "^2.10.1",
    "swiper": "^11.0.5",
    "tailwind-merge": "^1.14.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/babel__core": "^7.20.1",
    "@types/babel__generator": "^7.6.4",
    "@types/babel__template": "^7.4.1",
    "@types/babel__traverse": "^7.20.1",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/react-syntax-highlighter": "^15.5.7",
    "@types/react-table": "^7.7.18",
    "@types/sinonjs__fake-timers": "^8.1.2",
    "@types/sizzle": "^2.3.5",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.4",
    "eslint": "^8.53.0",
    "eslint-config-next": "^15.3.2",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2"
  }
}
